<UserControl x:Class="Vendex.App.Views.RelatoriosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Filtros -->
        <Border Grid.Row="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20" Margin="0,0,0,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Relatório" Margin="0,0,0,4" Foreground="#6B7280" FontSize="12" />
                        <ComboBox ItemsSource="{Binding Opcoes}" DisplayMemberPath="Nome"
                                  SelectedItem="{Binding OpcaoSelecionada}" Width="280" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" Visibility="{Binding PrecisaPeriodo, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="De" Margin="0,0,0,4" Foreground="#6B7280" FontSize="12" />
                        <DatePicker SelectedDate="{Binding DataInicio}" Width="140" />
                    </StackPanel>

                    <StackPanel Grid.Column="4" Visibility="{Binding PrecisaPeriodo, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Até" Margin="0,0,0,4" Foreground="#6B7280" FontSize="12" />
                        <DatePicker SelectedDate="{Binding DataFim}" Width="140" />
                    </StackPanel>

                    <ui:Button Grid.Column="6" Content="Gerar" Appearance="Primary" Padding="24,8"
                               VerticalAlignment="Bottom" Command="{Binding GerarCommand}" />
                </Grid>

                <TextBlock Text="{Binding MensagemErro}" Foreground="#C4291E" Margin="0,12,0,0" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <!-- Resultado -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,0,12"
                        Visibility="{Binding TemResultado, Converter={StaticResource BoolToVisibilityConverter}}">
                <ui:ProgressRing IsIndeterminate="True" Width="18" Height="18" Margin="0,0,12,0"
                                  Visibility="{Binding Exportando, Converter={StaticResource BoolToVisibilityConverter}}" />
                <ui:Button Content="Exportar Excel" Margin="0,0,8,0" Command="{Binding ExportarExcelCommand}" IsEnabled="{Binding PodeExportar}" />
                <ui:Button Content="Exportar PDF" Command="{Binding ExportarPdfCommand}" IsEnabled="{Binding PodeExportar}" />
            </StackPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                <ListView x:Name="ListaResultado" ItemsSource="{Binding Resultado.Linhas}" BorderThickness="0" Background="Transparent" />
            </Border>

            <TextBlock Grid.Row="2" Text="{Binding TotaisFormatados}" FontWeight="Bold" Foreground="#1F2430"
                       Margin="0,12,0,0" HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</UserControl>
