<UserControl x:Class="Vendex.App.Views.ReciboView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
            <Border Width="80" Height="80" CornerRadius="40" Background="#DCF5E3" HorizontalAlignment="Center" Margin="0,0,0,16">
                <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="40" Foreground="#1B8A4B"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <TextBlock Text="Venda finalizada com sucesso!" FontSize="20" FontWeight="SemiBold"
                       Foreground="#1F2430" HorizontalAlignment="Center" Margin="0,0,0,4" />
            <TextBlock HorizontalAlignment="Center" Foreground="#6B7280" FontSize="12" Margin="0,0,0,24">
                <Run Text="Venda #" /><Run Text="{Binding NumeroVenda, Mode=OneWay}" />
                <Run Text=" — " /><Run Text="{Binding DataHora, Mode=OneWay, StringFormat='dd/MM/yyyy HH:mm'}" />
            </TextBlock>

            <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20"
                    x:Name="ReciboParaImprimir" MinWidth="380">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Itens}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Foreground="#1F2430">
                                        <Run Text="{Binding Quantidade, Mode=OneWay}" />
                                        <Run Text="× " />
                                        <Run Text="{Binding Nome, Mode=OneWay}" />
                                    </TextBlock>
                                    <TextBlock Grid.Column="1" Text="{Binding SubtotalFormatado}" Foreground="#1F2430" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,8" />

                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Total" FontWeight="Bold" Foreground="#1F2430" />
                        <TextBlock Grid.Column="1" Text="{Binding TotalFormatado}" FontWeight="Bold" Foreground="#1F2430" />
                    </Grid>

                    <ItemsControl ItemsSource="{Binding PagamentosTexto}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#6B7280" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Foreground="#1B8A4B" FontWeight="SemiBold"
                               Visibility="{Binding TrocoTotalFormatado, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="Troco: " /><Run Text="{Binding TrocoTotalFormatado, Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Foreground="#6B7280"
                               Visibility="{Binding ClienteTexto, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="Cliente: " /><Run Text="{Binding ClienteTexto, Mode=OneWay}" />
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <ui:Button Content="Imprimir cupom" Padding="16,10" Click="Imprimir_Click" Margin="0,0,16,0" />
            <ui:Button Content="Nova Venda" Appearance="Primary" Padding="24,10"
                       Command="{Binding DataContext.NovaVendaCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
        </StackPanel>
    </Grid>
</UserControl>
