<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Vendex.Application\Vendex.Application.csproj" />
    <ProjectReference Include="..\Vendex.Data\Vendex.Data.csproj" />
    <ProjectReference Include="..\Vendex.Licensing\Vendex.Licensing.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="Assets\vendex-icon.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
    <PackageReference Include="WPF-UI" Version="3.0.5" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\vendex-icon.ico</ApplicationIcon>
    <AssemblyTitle>Vendex PDV</AssemblyTitle>
    <Product>Vendex PDV</Product>
    <Company>Vendex</Company>
    <Version>1.0.0</Version>
    <FileVersion>1.0.0.0</FileVersion>
  </PropertyGroup>

</Project>
