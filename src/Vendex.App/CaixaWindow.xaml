<ui:FluentWindow x:Class="Vendex.App.CaixaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Vendex.App.ViewModels"
        mc:Ignorable="d"
        Title="Caixa" Height="720" Width="640"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <ui:FluentWindow.Resources>
        <DataTemplate x:Key="ModeloLinhaCedula" DataType="{x:Type vm:CedulaLinhaViewModel}">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ValorFormatado}" VerticalAlignment="Center" Foreground="#1F2430" />
                <ui:TextBox Grid.Column="1" Text="{Binding Quantidade, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Grid.Column="2" Text="{Binding SubtotalFormatado}" VerticalAlignment="Center"
                           HorizontalAlignment="Right" Foreground="#6B7280" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ModeloLinhaCedulaReadOnly" DataType="{x:Type vm:CedulaLinhaViewModel}">
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ValorFormatado}" Foreground="#1F2430" />
                <TextBlock Grid.Column="1" Foreground="#6B7280" Margin="0,0,16,0">
                    <Run Text="{Binding Quantidade, Mode=OneWay}" /><Run Text=" un." />
                </TextBlock>
                <TextBlock Grid.Column="2" Text="{Binding SubtotalFormatado}" Foreground="#1F2430" FontWeight="Medium" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ModeloContagem">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Notas" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" Foreground="#1F2430" />
                    <ItemsControl ItemsSource="{Binding LinhasNotas}" ItemTemplate="{StaticResource ModeloLinhaCedula}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Moedas" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" Foreground="#1F2430" />
                    <ItemsControl ItemsSource="{Binding LinhasMoedas}" ItemTemplate="{StaticResource ModeloLinhaCedula}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Caixa" />

        <Grid Grid.Row="1" Margin="0,16,0,0">

            <!-- Abrir: formulário de contagem -->
            <Grid Visibility="{Binding MostrarAbrirForm, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Contagem de abertura de caixa" FontSize="16" FontWeight="SemiBold"
                           Foreground="#1F2430" Margin="0,0,0,16" />
                <ContentControl Grid.Row="1" Content="{Binding}" ContentTemplate="{StaticResource ModeloContagem}" />
                <Border Grid.Row="2" Background="#EDEBFF" CornerRadius="10" Padding="16,12" Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Total em caixa" FontWeight="Medium" Foreground="#5B4FE9" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding TotalContadoFormatado}" FontWeight="Bold" FontSize="20" Foreground="#5B4FE9" />
                    </Grid>
                </Border>
                <TextBlock Grid.Row="3" Text="{Binding MensagemErro}" Foreground="#C4291E" Margin="0,12,0,0" TextWrapping="Wrap" />
                <ui:Button Grid.Row="4" Content="Abrir Caixa" Appearance="Primary" Command="{Binding AbrirCommand}"
                           HorizontalAlignment="Right" Padding="24,8" Margin="0,16,0,0" />
            </Grid>

            <!-- Abrir: recibo -->
            <StackPanel Visibility="{Binding MostrarAbrirRecibo, Converter={StaticResource BoolToVisibilityConverter}}">
                <Border Width="80" Height="80" CornerRadius="40" Background="#DCF5E3" HorizontalAlignment="Center" Margin="0,20,0,16">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="40" Foreground="#1B8A4B"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Caixa aberto com sucesso!" FontSize="20" FontWeight="SemiBold"
                           Foreground="#1F2430" HorizontalAlignment="Center" Margin="0,0,0,4" />
                <TextBlock Text="{Binding ReciboAberturaDataFormatada}" Foreground="#6B7280" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,24" />

                <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20"
                        x:Name="ReciboAberturaParaImprimir" HorizontalAlignment="Center" MinWidth="380">
                    <StackPanel>
                        <TextBlock Text="Abertura de Caixa" FontWeight="Bold" Foreground="#1F2430" Margin="0,0,0,4" />
                        <TextBlock Text="{Binding ReciboAberturaDataFormatada}" Foreground="#6B7280" FontSize="12" Margin="0,0,0,12" />
                        <ItemsControl ItemsSource="{Binding ReciboAberturaLinhas}" ItemTemplate="{StaticResource ModeloLinhaCedulaReadOnly}" />
                        <Separator Margin="0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Total de abertura" FontWeight="Bold" Foreground="#1F2430" />
                            <TextBlock Grid.Column="1" Text="{Binding ReciboAberturaTotalFormatado}" FontWeight="Bold" Foreground="#1F2430" />
                        </Grid>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <ui:Button Content="Imprimir" Padding="16,10" Click="ImprimirAbertura_Click" Margin="0,0,16,0" />
                    <ui:Button Content="Concluir" Appearance="Primary" Padding="24,10" Command="{Binding ConcluirCommand}" />
                </StackPanel>
            </StackPanel>

            <!-- Fechar: resumo do caixa aberto -->
            <StackPanel Visibility="{Binding MostrarFecharResumo, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,40,0,0" HorizontalAlignment="Center">
                <TextBlock Text="Caixa aberto" FontSize="18" FontWeight="SemiBold" Foreground="#1F2430"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock HorizontalAlignment="Center" Foreground="#6B7280" Margin="0,0,0,24">
                    <Run Text="Desde " /><Run Text="{Binding ResumoAberturaDataFormatada, Mode=OneWay}" />
                    <Run Text=" — valor inicial de " /><Run Text="{Binding ResumoAberturaValorFormatado, Mode=OneWay}" />
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <ui:Button Content="Sangria" Padding="18,10" Margin="0,0,12,0" Command="{Binding SangriaCommand}" />
                    <ui:Button Content="Suprimento" Padding="18,10" Command="{Binding SuprimentoCommand}" />
                </StackPanel>
                <ui:Button Content="Fechar Caixa" Appearance="Primary" Padding="24,10"
                           HorizontalAlignment="Center" Command="{Binding IniciarFechamentoCommand}" />
            </StackPanel>

            <!-- Fechar: formulário de contagem -->
            <Grid Visibility="{Binding MostrarFecharForm, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Contagem de fechamento de caixa" FontSize="16" FontWeight="SemiBold"
                           Foreground="#1F2430" Margin="0,0,0,16" />
                <ContentControl Grid.Row="1" Content="{Binding}" ContentTemplate="{StaticResource ModeloContagem}" />
                <Border Grid.Row="2" Background="#F3F4F8" CornerRadius="10" Padding="16,12" Margin="0,16,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Valor esperado em caixa (abertura + vendas em dinheiro + suprimentos − sangrias)"
                                   FontWeight="Medium" Foreground="#6B7280" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,12,0" />
                        <TextBlock Grid.Column="1" Text="{Binding ValorEsperadoFechamentoFormatado}" FontWeight="Bold" FontSize="16" Foreground="#1F2430" />
                    </Grid>
                </Border>
                <Border Grid.Row="3" Background="#EDEBFF" CornerRadius="10" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Total contado em caixa" FontWeight="Medium" Foreground="#5B4FE9" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding TotalContadoFormatado}" FontWeight="Bold" FontSize="20" Foreground="#5B4FE9" />
                    </Grid>
                </Border>
                <TextBlock Grid.Row="4" Text="{Binding MensagemErro}" Foreground="#C4291E" Margin="0,12,0,0" TextWrapping="Wrap" />
                <ui:Button Grid.Row="5" Content="Confirmar Fechamento" Appearance="Primary" Command="{Binding FecharCommand}"
                           HorizontalAlignment="Right" Padding="24,8" Margin="0,16,0,0" />
            </Grid>

            <!-- Fechar: recibo -->
            <ScrollViewer Visibility="{Binding MostrarFecharRecibo, Converter={StaticResource BoolToVisibilityConverter}}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Width="80" Height="80" CornerRadius="40" Background="#DCF5E3" HorizontalAlignment="Center" Margin="0,20,0,16">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="40" Foreground="#1B8A4B"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Caixa fechado com sucesso!" FontSize="20" FontWeight="SemiBold"
                               Foreground="#1F2430" HorizontalAlignment="Center" Margin="0,0,0,24" />

                    <Border Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20"
                            x:Name="ReciboFechamentoParaImprimir" HorizontalAlignment="Center" MinWidth="420">
                        <StackPanel>
                            <TextBlock Text="Fechamento de Caixa" FontWeight="Bold" Foreground="#1F2430" Margin="0,0,0,4" />
                            <TextBlock Foreground="#6B7280" FontSize="12" Margin="0,0,0,12">
                                <Run Text="Abertura: " /><Run Text="{Binding FechamentoDataAberturaFormatada, Mode=OneWay}" />
                                <Run Text=" — Fechamento: " /><Run Text="{Binding FechamentoDataFechamentoFormatada, Mode=OneWay}" />
                            </TextBlock>

                            <TextBlock Text="Contagem final" FontWeight="SemiBold" Foreground="#1F2430" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding ReciboFechamentoLinhas}" ItemTemplate="{StaticResource ModeloLinhaCedulaReadOnly}" />
                            <Separator Margin="0,8" />

                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Valor de abertura" Foreground="#6B7280" />
                                <TextBlock Grid.Column="1" Text="{Binding FechamentoValorAberturaFormatado}" Foreground="#1F2430" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Valor esperado em caixa" Foreground="#6B7280" />
                                <TextBlock Grid.Column="1" Text="{Binding FechamentoEsperadoFormatado}" Foreground="#1F2430" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Valor contado no fechamento" FontWeight="Bold" Foreground="#1F2430" />
                                <TextBlock Grid.Column="1" Text="{Binding FechamentoValorFechamentoFormatado}" FontWeight="Bold" Foreground="#1F2430" />
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Divergência" FontWeight="Bold" Foreground="#1F2430" />
                                <TextBlock Grid.Column="1" Text="{Binding FechamentoDivergenciaFormatado}" FontWeight="Bold" Foreground="#1F2430" />
                            </Grid>

                            <Separator Margin="0,0,0,8" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Faturamento do dia" Foreground="#6B7280" />
                                <TextBlock Grid.Column="1" Text="{Binding FechamentoFaturamentoFormatado}" Foreground="#1F2430" />
                            </Grid>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Custo dos produtos vendidos" Foreground="#6B7280" />
                                <TextBlock Grid.Column="1" Text="{Binding FechamentoCustoFormatado}" Foreground="#1F2430" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Lucro do dia" FontWeight="Bold" Foreground="#1B8A4B" />
                                <TextBlock Grid.Column="1" Text="{Binding FechamentoLucroFormatado}" FontWeight="Bold" Foreground="#1B8A4B" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,20">
                        <ui:Button Content="Imprimir" Padding="16,10" Click="ImprimirFechamento_Click" Margin="0,0,16,0" />
                        <ui:Button Content="Concluir" Appearance="Primary" Padding="24,10" Command="{Binding ConcluirCommand}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
