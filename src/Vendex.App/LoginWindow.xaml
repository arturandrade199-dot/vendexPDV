<ui:FluentWindow x:Class="Vendex.App.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Vendex PDV — Login" Height="600" Width="400" MinHeight="460"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        ResizeMode="CanResize">
    <Grid Margin="32,0,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vendex PDV" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel VerticalAlignment="Center">
            <Image Source="/Assets/vendex-icon.png" Width="72" Height="72" HorizontalAlignment="Center" Margin="0,0,0,24" />

            <!-- Primeiro acesso: criar administrador -->
            <StackPanel Visibility="{Binding ModoCriarPrimeiroAdministrador, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="Bem-vindo! Crie o usuário administrador" FontSize="16" FontWeight="SemiBold"
                           Foreground="#1F2430" HorizontalAlignment="Center" Margin="0,0,0,20"
                           TextWrapping="Wrap" TextAlignment="Center" />

                <TextBlock Text="Nome" Margin="0,0,0,4" />
                <ui:TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <TextBlock Text="Login" Margin="0,0,0,4" />
                <ui:TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <TextBlock Text="Senha" Margin="0,0,0,4" />
                <PasswordBox x:Name="PasswordBoxCriar" Margin="0,0,0,12"
                             PasswordChanged="PasswordBoxCriar_PasswordChanged" />

                <TextBlock Text="Confirmar senha" Margin="0,0,0,4" />
                <PasswordBox x:Name="PasswordBoxConfirmar" Margin="0,0,0,12"
                             PasswordChanged="PasswordBoxConfirmar_PasswordChanged" />

                <TextBlock Text="{Binding MensagemErro}" Foreground="#C4291E" Margin="0,0,0,12"
                           TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />

                <ui:Button Content="Criar Administrador" Appearance="Primary" Command="{Binding CriarAdministradorCommand}"
                           HorizontalAlignment="Stretch" Padding="0,10" />
            </StackPanel>

            <!-- Login normal -->
            <StackPanel Visibility="{Binding ModoCriarPrimeiroAdministrador, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                <TextBlock Text="Entrar" FontSize="18" FontWeight="SemiBold" Foreground="#1F2430"
                           HorizontalAlignment="Center" Margin="0,0,0,20" />

                <TextBlock Text="Login" Margin="0,0,0,4" />
                <ui:TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                <TextBlock Text="Senha" Margin="0,0,0,4" />
                <PasswordBox x:Name="PasswordBoxLogin" Margin="0,0,0,12"
                             PasswordChanged="PasswordBoxLogin_PasswordChanged">
                    <PasswordBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding EntrarCommand}" />
                    </PasswordBox.InputBindings>
                </PasswordBox>

                <TextBlock Text="{Binding MensagemErro}" Foreground="#C4291E" Margin="0,0,0,12"
                           TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />

                <ui:Button Content="Entrar" Appearance="Primary" Command="{Binding EntrarCommand}"
                           HorizontalAlignment="Stretch" Padding="0,10" />
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
