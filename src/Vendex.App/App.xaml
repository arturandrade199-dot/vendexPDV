<Application x:Class="Vendex.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:Vendex.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
            <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
            <conv:AllTrueToVisibilityConverter x:Key="AllTrueToVisibilityConverter" />
            <conv:PathToImageSourceConverter x:Key="PathToImageSourceConverter" />

            <!-- Estilos compartilhados do "design moderno" — reaproveitados em todas as telas de módulo -->
            <Style x:Key="CartaoResumo" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="BorderThickness" Value="1,1,1,4" />
                <Setter Property="Padding" Value="16,14" />
                <Setter Property="Margin" Value="0,0,12,0" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.06" Color="Black" />
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="RotuloResumo" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#6B7280" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Margin" Value="0,0,0,6" />
            </Style>

            <Style x:Key="ValorResumo" TargetType="TextBlock">
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#1F2430" />
            </Style>

            <Style x:Key="IconeMenu" TargetType="Border">
                <Setter Property="Width" Value="44" />
                <Setter Property="Height" Value="44" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style x:Key="CartaoModulo" TargetType="Border">
                <Setter Property="Background" Value="White" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="BorderBrush" Value="#E5E7EB" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="18" />
                <Setter Property="Margin" Value="0,0,16,16" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="1" Opacity="0.05" Color="Black" />
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Disponivel}" Value="False">
                        <Setter Property="Opacity" Value="0.55" />
                        <Setter Property="Cursor" Value="Arrow" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
