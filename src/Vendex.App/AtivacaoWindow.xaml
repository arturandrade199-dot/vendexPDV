<ui:FluentWindow x:Class="Vendex.App.AtivacaoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Vendex PDV — Ativação" Height="420" Width="400"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        ResizeMode="NoResize">
    <Grid Margin="32,0,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vendex PDV" />

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Image Source="/Assets/vendex-icon.png" Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,20" />

            <TextBlock Text="Ativar assinatura" FontSize="18" FontWeight="SemiBold" Foreground="#1F2430"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="Informe o email usado na compra — depois disso o app confere sozinho, sem precisar digitar nada de novo."
                       Foreground="#6B7280" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20" />

            <TextBlock Text="Email" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12">
                <ui:TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding AtivarCommand}" />
                </ui:TextBox.InputBindings>
            </ui:TextBox>

            <TextBlock Text="{Binding MensagemErro}" Foreground="#C4291E" Margin="0,0,0,12"
                       TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" />

            <ui:Button Content="Ativar" Appearance="Primary" Command="{Binding AtivarCommand}"
                       IsEnabled="{Binding PodeAtivar}"
                       HorizontalAlignment="Stretch" Padding="0,10" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
