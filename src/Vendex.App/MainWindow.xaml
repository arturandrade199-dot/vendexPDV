<ui:FluentWindow x:Class="Vendex.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Vendex.App.ViewModels"
        xmlns:views="clr-namespace:Vendex.App.Views"
        mc:Ignorable="d"
        Title="Vendex PDV" Height="760" Width="1240"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <Style x:Key="IconeContasPagar" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Contas a pagar">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconeProdutos" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Produtos">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconeFornecedores" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Fornecedores">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconeContasReceber" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Contas a receber">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconeClientes" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Clientes">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconeUsuarios" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Usuários">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconeRelatorios" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Relatórios">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="#F3F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vendex PDV" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="#5B4FE9" Margin="0,0,0,28"
                            Cursor="Hand" ToolTip="Menu principal">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaMenuCommand}" />
                        </Border.InputBindings>
                        <TextBlock Text="VX" Foreground="White" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <Border Style="{StaticResource IconeContasPagar}" ToolTip="Contas a Pagar — Despesas e obrigações da loja" Cursor="Hand"
                            Visibility="{Binding PodeAcessarContasPagar, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaContasPagarCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="Wallet24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeMenu}" ToolTip="PDV — Registrar vendas no balcão" Cursor="Hand"
                            Visibility="{Binding PodeAcessarPdv, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding AbrirPdvCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="Cart24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeProdutos}" ToolTip="Produtos — Cadastro de produtos" Cursor="Hand"
                            Visibility="{Binding PodeAcessarProdutos, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaProdutosCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="Box24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeClientes}" ToolTip="Clientes — Cadastro vinculado a Contas a Receber" Cursor="Hand"
                            Visibility="{Binding PodeAcessarClientes, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaClientesCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="People24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeFornecedores}" ToolTip="Fornecedores — Cadastro vinculado a Contas a Pagar" Cursor="Hand"
                            Visibility="{Binding PodeAcessarFornecedores, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaFornecedoresCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="Building24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeContasReceber}" ToolTip="Contas a Receber — Vendas a prazo e parceladas" Cursor="Hand"
                            Visibility="{Binding PodeAcessarContasReceber, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaContasReceberCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="ReceiptMoney24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeUsuarios}" ToolTip="Usuários e Permissões — Funcionários e acessos" Cursor="Hand"
                            Visibility="{Binding EhAdministrador, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaUsuariosCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="PeopleSettings24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeRelatorios}" ToolTip="Relatórios — Vendas, financeiro e auditoria" Cursor="Hand"
                            Visibility="{Binding EhAdministrador, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaRelatoriosCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="DocumentBulletList24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Conteúdo -->
            <Grid Grid.Column="1" Margin="32,20,32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Cabeçalho -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ui:Button Content="← Menu" Appearance="Transparent" Padding="0,0,16,0"
                                   Command="{Binding IrParaMenuCommand}"
                                   Visibility="{Binding MostrarBotaoVoltar, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="{Binding TituloAtual}" FontSize="22" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Foreground="#1F2430" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Cursor="Hand"
                                ToolTip="{Binding NomeComPerfilUsuarioLogado}">
                        <StackPanel.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding AbrirPerfilCommand}" />
                        </StackPanel.InputBindings>

                        <Grid Width="32" Height="32" Margin="0,0,8,0">
                            <Border CornerRadius="16" Background="#5B4FE9">
                                <TextBlock Text="{Binding IniciaisUsuarioLogado}" Foreground="White" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <Ellipse Visibility="{Binding FotoUsuarioLogado, Converter={StaticResource NullToVisibilityConverter}}">
                                <Ellipse.Fill>
                                    <ImageBrush ImageSource="{Binding FotoUsuarioLogado, Converter={StaticResource PathToImageSourceConverter}}" Stretch="UniformToFill" />
                                </Ellipse.Fill>
                            </Ellipse>
                        </Grid>

                        <TextBlock Text="{Binding NomeComPerfilUsuarioLogado}" VerticalAlignment="Center" Foreground="#1F2430" />
                    </StackPanel>
                </Grid>

                <!-- Módulo atual -->
                <ContentControl Grid.Row="1" Content="{Binding ConteudoAtual}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:MenuViewModel}">
                            <views:MenuView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ContasPagarViewModel}">
                            <views:ContasPagarView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ProdutosViewModel}">
                            <views:ProdutosView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:FornecedoresViewModel}">
                            <views:FornecedoresView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ContasReceberViewModel}">
                            <views:ContasReceberView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ClientesViewModel}">
                            <views:ClientesView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:UsuariosViewModel}">
                            <views:UsuariosView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ConfiguracaoBackupViewModel}">
                            <views:ConfiguracaoBackupView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:RelatoriosViewModel}">
                            <views:RelatoriosView />
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
