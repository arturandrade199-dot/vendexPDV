<ui:FluentWindow x:Class="Vendex.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:Vendex.App.ViewModels"
        xmlns:views="clr-namespace:Vendex.App.Views"
        mc:Ignorable="d"
        Title="Vendex PDV" Height="760" Width="1240"
        MinHeight="600" MinWidth="900"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <ui:FluentWindow.Resources>
        <Style x:Key="IconeContasPagar" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Contas a pagar">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="IconeProdutos" TargetType="Border" BasedOn="{StaticResource IconeMenu}">
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TituloAtual}" Value="Produtos">
                    <Setter Property="Background" Value="#EDEBFF" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="#F3F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vendex PDV" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="76" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <StackPanel Margin="0,20,0,0" HorizontalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10" Background="#5B4FE9" Margin="0,0,0,28"
                            Cursor="Hand" ToolTip="Menu principal">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaMenuCommand}" />
                        </Border.InputBindings>
                        <TextBlock Text="VX" Foreground="White" FontWeight="Bold" FontSize="14"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>

                    <Border Style="{StaticResource IconeContasPagar}" ToolTip="Contas a Pagar" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaContasPagarCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="Wallet24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeMenu}" Opacity="0.55" ToolTip="PDV — em breve">
                        <ui:SymbolIcon Symbol="Cart24" Foreground="#6B7280"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeProdutos}" ToolTip="Produtos" Cursor="Hand">
                        <Border.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{Binding IrParaProdutosCommand}" />
                        </Border.InputBindings>
                        <ui:SymbolIcon Symbol="Box24" Foreground="#5B4FE9"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeMenu}" Opacity="0.55" ToolTip="Clientes e Fornecedores — em breve">
                        <ui:SymbolIcon Symbol="People24" Foreground="#6B7280"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <Border Style="{StaticResource IconeMenu}" Opacity="0.55" ToolTip="Relatórios — em breve">
                        <ui:SymbolIcon Symbol="DocumentBulletList24" Foreground="#6B7280"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Conteúdo -->
            <Grid Grid.Column="1" Margin="32,20,32,24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Cabeçalho -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ui:Button Content="← Menu" Appearance="Transparent" Padding="0,0,16,0"
                                   Command="{Binding IrParaMenuCommand}"
                                   Visibility="{Binding MostrarBotaoVoltar, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="{Binding TituloAtual}" FontSize="22" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Foreground="#1F2430" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Width="32" Height="32" CornerRadius="16" Background="#5B4FE9" Margin="0,0,8,0">
                            <TextBlock Text="A" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Administrador" VerticalAlignment="Center" Foreground="#1F2430" />
                    </StackPanel>
                </Grid>

                <!-- Módulo atual -->
                <ContentControl Grid.Row="1" Content="{Binding ConteudoAtual}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:MenuViewModel}">
                            <views:MenuView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ContasPagarViewModel}">
                            <views:ContasPagarView />
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ProdutosViewModel}">
                            <views:ProdutosView />
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
