<ui:FluentWindow x:Class="Vendex.App.PdvWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:Vendex.App.Views"
        mc:Ignorable="d"
        Title="Vendex PDV — Venda" Height="800" Width="1280"
        WindowState="Maximized"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        WindowCornerPreference="Round">

    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="F2" Command="{Binding FinalizarVendaCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelarVendaCommand}" />
    </ui:FluentWindow.InputBindings>

    <Grid Background="#F3F4F8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Vendex PDV — Venda" />

        <!-- Status do caixa -->
        <Border Grid.Row="1" Margin="24,16,24,16" CornerRadius="16" Padding="20,16" Background="#EDEBFF">
            <TextBlock Text="{Binding RotuloStatusCaixa}" FontWeight="Bold" FontSize="28" Foreground="#5B4FE9"
                       HorizontalAlignment="Center" />
        </Border>

        <!-- Corpo -->
        <Grid Grid.Row="2" Margin="24,0,24,16">
            <!-- Estado normal: busca + (logo ou grid do carrinho) -->
            <Grid Visibility="{Binding MostrarCarrinho, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Busca e quantidade -->
                <Border Grid.Column="0" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Buscar produto (nome ou código de barras)" Margin="0,0,0,6" Foreground="#6B7280" FontSize="12" />
                        <ui:TextBox x:Name="TxtBusca" FontSize="18" Padding="10"
                                    Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}">
                            <ui:TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding AdicionarPrimeiroResultadoCommand}" />
                            </ui:TextBox.InputBindings>
                        </ui:TextBox>

                        <TextBlock Text="Quantidade" Margin="0,16,0,6" Foreground="#6B7280" FontSize="12" />
                        <ui:TextBox Text="{Binding QuantidadeTexto, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="18" Padding="10" />

                        <ListBox ItemsSource="{Binding ResultadosBusca}" Margin="0,16,0,0" BorderThickness="0" Background="Transparent"
                                 MaxHeight="360">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F7F7FB" CornerRadius="8" Padding="12,10" Margin="0,0,0,8" Cursor="Hand">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.AdicionarProdutoCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                          CommandParameter="{Binding}" />
                                        </Border.InputBindings>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Nome}" FontWeight="Medium" Foreground="#1F2430" />
                                            <TextBlock Text="{Binding PrecoVenda, StringFormat='Preço: {0:C2}'}" Foreground="#6B7280" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Itens da venda: logo enquanto o carrinho está vazio, grid assim que o primeiro item entra -->
                <Border Grid.Column="2" Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                    <Grid>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding TemItens, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <Image Source="/Assets/vendex-icon.png" Width="140" Height="140" Opacity="0.85" />
                            <TextBlock Text="Busque um produto e informe a quantidade para começar a venda"
                                       Foreground="#6B7280" FontSize="14" Margin="0,20,0,0"
                                       HorizontalAlignment="Center" TextAlignment="Center" MaxWidth="320" TextWrapping="Wrap" />
                        </StackPanel>

                        <ListView ItemsSource="{Binding Itens}" BorderThickness="0" Background="Transparent"
                                  Visibility="{Binding TemItens, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Produto" Width="320">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Nome}" Foreground="#1F2430" FontSize="14" Padding="0,6" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Preço Unit." Width="140">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding PrecoUnitarioFormatado}" Foreground="#1F2430" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Quantidade" Width="140">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Quantidade}" Foreground="#1F2430" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Subtotal" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SubtotalFormatado}" FontWeight="SemiBold" Foreground="#1F2430" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <ui:Button Content="Remover"
                                                           Command="{Binding DataContext.RemoverItemCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                                           CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- Estado de pagamento: substitui o grid por inteiro, como um modal embutido -->
            <Border Visibility="{Binding EstaEmPagamento, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                <views:PagamentoView DataContext="{Binding PagamentoAtual}" />
            </Border>

            <!-- Estado de recibo: também substitui o grid por inteiro, como um modal embutido -->
            <Border Visibility="{Binding EstaComRecibo, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="White" CornerRadius="12" BorderBrush="#E5E7EB" BorderThickness="1">
                <views:ReciboView DataContext="{Binding ReciboAtual}" />
            </Border>
        </Grid>

        <!-- Barra de atalhos / finalização -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="24,16"
                Visibility="{Binding MostrarCarrinho, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding Mensagem}" Foreground="#6B7280" VerticalAlignment="Center" Margin="0,0,16,0" />
                    <ui:Button Content="Sangria" IsEnabled="False" ToolTip="Em breve" Margin="0,0,8,0" />
                    <ui:Button Content="Suprimento" IsEnabled="False" ToolTip="Em breve" Margin="0,0,8,0" />
                    <ui:Button Content="Caixa" IsEnabled="False" ToolTip="Em breve" />
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,24,0"
                            Visibility="{Binding TemItens, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Total" Foreground="#6B7280" FontSize="12" />
                    <TextBlock Text="{Binding TotalFormatado}" FontSize="24" FontWeight="Bold" Foreground="#1F2430" />
                </StackPanel>

                <ui:Button Grid.Column="2" Content="Cancelar Venda (Esc)" Margin="0,0,12,0" Padding="16,10"
                           Command="{Binding CancelarVendaCommand}" />

                <ui:Button Grid.Column="3" Content="Finalizar Venda (F2)" Appearance="Primary" Padding="16,10"
                           Command="{Binding FinalizarVendaCommand}" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
