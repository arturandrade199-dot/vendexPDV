<ui:FluentWindow x:Class="Vendex.App.ClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:behaviors="clr-namespace:Vendex.App.Behaviors"
        mc:Ignorable="d"
        Title="{Binding Titulo}" Height="620" Width="440"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid Margin="24,0,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding Titulo}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Text="Nome" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

            <TextBlock Text="Telefone" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Telefone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                        behaviors:Mascara.Tipo="Telefone" />

            <TextBlock Text="Documento (CPF)" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Documento, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                        behaviors:Mascara.Tipo="Cpf" />

            <TextBlock Text="Endereço" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Endereco, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

            <TextBlock Text="Limite de crédito (R$)" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding LimiteCreditoTexto, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

            <TextBlock Text="Observações" Margin="0,0,0,4" />
            <ui:TextBox Text="{Binding Observacoes, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                        AcceptsReturn="True" TextWrapping="Wrap" Height="70" />

            <TextBlock Text="{Binding MensagemErro}" Foreground="#C4291E" Margin="0,0,0,12" TextWrapping="Wrap" />

            <ui:Button Content="Salvar" Appearance="Primary" Command="{Binding SalvarCommand}"
                       HorizontalAlignment="Right" Padding="24,8" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
